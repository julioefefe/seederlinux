+  screensaverTimeout    Int      @default(900) @map("screensaver_timeout")
+  powerTimeout          Int      @default(1800) @map("power_timeout")
+  lockTimeout           Int      @default(600)  @map("lock_timeout")
+  createdAt             DateTime @default(now())
+  updatedAt             DateTime @updatedAt
+
+  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
+
+  @@map("desktop_policies")
+}
+
+// =============================================================================
+// OFFLINE AUTH POLICIES (Documento 04 §4 / Documento 14 §28)
+// =============================================================================
+
+model OfflineAuthPolicy {
+  orgId             String   @id @map("org_id")
+  enabled           Boolean  @default(true)
+  cacheCredentials  Boolean  @default(true) @map("cache_credentials")
+  offlineDays       Int      @default(30)   @map("offline_days")
+  maxOfflineLogins  Int      @default(10)   @map("max_offline_logins")
+  autoSync          Boolean  @default(true) @map("auto_sync")
+  sssdConfig        String?  @map("sssd_config")  @db.Text
+  adDomain          String?  @map("ad_domain")
