 // SeederLinux v3.0 API Client
 // Fastify + Prisma backend via fetch()
 
-const API_URL = import.meta.env.VITE_API_URL || 'http://localhost:8000';
+/**
+ * Resolve a URL base da API:
+ * 1. VITE_API_URL explícito tem prioridade
+ * 2. Caso contrário, deriva do protocolo da página:
+ *    - https://seederlinux.local → https://seederlinux.local:8000
+ *    - http://localhost:3000 → http://localhost:8000
+ * Isso garante que, quando o TLS estiver ativo (Doc 15 v3.1),
+ * o frontend chame a API por HTTPS automaticamente — evitando
+ * mixed-content e erros de CORS por mismatch de scheme.
+ */
+function resolveApiUrl(): string {
+  const explicit = import.meta.env.VITE_API_URL as string | undefined;
+  if (explicit && explicit.trim()) return explicit.trim().replace(/\/+$/, '');
+
+  if (typeof window !== 'undefined' && window.location) {
+    const { protocol, hostname } = window.location;
+    const apiPort = (import.meta.env.VITE_API_PORT as string | undefined) || '8000';
+    return `${protocol}//${hostname}:${apiPort}`;
+  }
+  return 'http://localhost:8000';
+}
+
+const API_URL = resolveApiUrl();
 
 let authToken: string | null = null;
 
