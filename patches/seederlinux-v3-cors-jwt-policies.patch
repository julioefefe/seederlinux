+  theme                 String   @default("Mint-Y-Dark")
+  iconTheme             String?  @map("icon_theme")
+  cursorTheme           String?  @map("cursor_theme")
+  font                  String?
+  soundsEnabled         Boolean  @default(true) @map("sounds_enabled")
