+/**
+ * TLS opcional no dev server (Documento 15 v3.1 — TLS-first).
+ * Ative com:
+ *   VITE_DEV_HTTPS=true
+ *   VITE_DEV_CERT=/path/to/server.crt
+ *   VITE_DEV_KEY=/path/to/server.key
+ * Os mesmos certificados gerados pelo Setup Wizard (TLS_DIR) podem ser
+ * reutilizados — o agente também precisa do CA para confiar.
+ */
+function buildDevHttps() {
+  if (process.env.VITE_DEV_HTTPS !== "true") return undefined;
+  const certPath = process.env.VITE_DEV_CERT;
+  const keyPath = process.env.VITE_DEV_KEY;
+  if (!certPath || !keyPath) return undefined;
+  try {
+    return {
+      cert: fs.readFileSync(certPath),
+      key: fs.readFileSync(keyPath),
+    };
+  } catch (err) {
+    // eslint-disable-next-line no-console
+    console.warn("[vite] VITE_DEV_HTTPS habilitado mas cert/key não foram lidos:", err);
+    return undefined;
+  }
+}
